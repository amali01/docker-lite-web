{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": ["dist/**"],
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-unused-vars": "off",
    "react/rules-of-hooks": "error"
  }
}
