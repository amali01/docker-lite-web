  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "app:install": "bash scripts/install-local.sh",
    "bootstrap:runtime": "tsx server/src/bootstrap.ts",
    "dev": "vite",
    "dev:full": "concurrently -k \"pnpm server:dev\" \"pnpm dev\"",
    "dev:mock": "concurrently -k \"pnpm server:dev:mock\" \"pnpm dev\"",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "oxlint",
    "preview": "vite preview",
    "server:dev": "tsx watch server/src/index.ts",
    "server:dev:mock": "DOCKLITE_ADAPTER=mock tsx watch server/src/index.ts",
    "server:start": "tsx server/src/index.ts",
    "server:start:mock": "DOCKLITE_ADAPTER=mock tsx server/src/index.ts",
    "server:test": "vitest run --config server/vitest.config.ts",
    "server:typecheck": "tsc -p server/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "FORCE_COLOR=0 playwright test"
  },
